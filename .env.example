# Firebase web app config. Copy this file to `.env` and fill in the values from
# Firebase console -> Project settings -> Your apps -> SDK setup and configuration.
# These are client-side identifiers (safe to ship in the browser bundle); access
# is controlled by Firebase Authentication + Firestore security rules, not secrecy.
# In Vercel, add each of these under Project Settings -> Environment Variables.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
