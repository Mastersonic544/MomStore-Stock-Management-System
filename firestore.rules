rules_version = '2';
// Shared inventory model: any signed-in staff member can read/write the shop's
// products and sales. Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read, write: if request.auth != null;
    }
    match /sales/{saleId} {
      // Sales are an audit trail: create + read only, never edit/delete.
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
