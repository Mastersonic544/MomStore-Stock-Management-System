rules_version = '2';
// Two coexisting models. Deploy with: firebase deploy --only firestore:rules
//  - Legacy/shared (top-level products & sales): any signed-in staff member can
//    read/write. Used by accounts created before the per-user-workspace change.
//  - Private workspaces (users/{uid}/...): only the owning user can touch their
//    own products & sales. Used by accounts created after the change, so each
//    new user starts on a blank, isolated canvas.
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read, write: if request.auth != null;
    }
    match /sales/{saleId} {
      // Sales are an audit trail: create + read only, never edit/delete.
      allow read, create: if request.auth != null;
      allow update, delete: if false;
    }

    match /users/{uid}/products/{productId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/sales/{saleId} {
      // Same immutable audit-trail rule, scoped to the owning user.
      allow read, create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false;
    }
  }
}
